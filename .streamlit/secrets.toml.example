# Copy this file to .streamlit/secrets.toml (which is gitignored) for local
# development, and paste the same values into the "Secrets" section of your
# app's settings on Streamlit Community Cloud for the deployed version.
#
# Get these from: Supabase project → Settings → API
#   SUPABASE_URL  = "Project URL"
#   SUPABASE_KEY  = "anon / public key"
#
# NOTE: the key currently hardcoded as a fallback in wc2026_app.py was
# committed to a public repo. Rotate it in Supabase (Settings → API →
# "Reset" on the anon key) and put the NEW key here only.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key"
